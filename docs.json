{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Linda UI",
  "theme": "almond",
  "colors": {
    "primary": "#0F766E",
    "light": "#CCEFED",
    "dark": "#0D5C56"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/francocarballar/lindaui"
