              "packages/blocks"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "71 accessible React components built on HeroUI v3 (react-aria-components)",
    "22 composable block sections for auth, lists, charts, and documents",
    "OKLCH teal brand design tokens with automatic light/dark mode",
    "Per-component entry points with no barrel import",
    "Mobile-first, responsive layouts (SplitWorkspace, ListPane, TablePane)",
    "6 chart block types (Area, Bar, Line, Pie, Radar, Radial) using recharts",
    "Token-driven theming with zero rebuild required",
    "TypeScript-first with stable, ergonomic flat APIs"
  ],
